{
  "name": "f1-dashboard",
  "version": "1.0.0",
  "description": "Desktop dashboard for the F1 game simulation.",
  "author": "F1 Game Team",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:dev": "concurrently -k \"vite\" \"wait-on tcp:3000 && cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron .\"",
    "desktop:build": "npm run desktop:build:linux",
    "desktop:build:linux": "cross-env ELECTRON_BUILD=1 npm run build && electron-builder --linux AppImage",
    "desktop:build:win": "cross-env ELECTRON_BUILD=1 npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12",
    "wait-on": "^9.0.3",
    "vite": "^5.1.0"
  },
  "build": {
    "appId": "com.f1game.dashboard",
    "productName": "F1 Dashboard",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    }
  }
}
