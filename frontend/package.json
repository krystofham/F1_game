{
  "name": "mmrac1ng",
  "version": "1.0.0",
  "description": "Game in Web user interface about motorsport racing",
  "author": "Kryštof Ham",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/krystofham/F1_game.git"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:dev": "concurrently -k \"vite\" \"wait-on tcp:3000 && cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron .\"",
    "desktop:build": "cross-env ELECTRON_BUILD=1 npm run build && electron-builder",
    "desktop:build:linux": "cross-env ELECTRON_BUILD=1 npm run build && electron-builder --linux AppImage",
    "desktop:build:win": "cross-env ELECTRON_BUILD=1 npm run build && electron-builder --win nsis",
    "desktop:build:mac": "cross-env ELECTRON_BUILD=1 npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12",
    "vite": "^5.1.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.mmrac1ng.game",
    "productName": "MMRAC1NG",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.games"
    }
  }
}
